{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "TextBlock",
      "text": "Magister Word of the Day",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "${word}",
      "weight": "ExtraBold",
      "size": "ExtraLarge",
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${definition}",
      "wrap": true,
      "italic": true,
      "spacing": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Practice Now",
      "url": "https://your-vercel-url.com/?tab=practice"
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}
